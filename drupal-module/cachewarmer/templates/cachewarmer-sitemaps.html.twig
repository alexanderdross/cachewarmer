{#
/**
 * @file
 * CacheWarmer sitemaps management template.
 *
 * Variables:
 * - sitemaps: array of sitemap objects.
 */
#}
<div class="cachewarmer-sitemaps">

  {# Add Sitemap Form #}
  <fieldset class="cachewarmer-add-sitemap-form">
    <legend>{{ 'Register Sitemap'|t }}</legend>
    <div class="cachewarmer-form-row">
      <label for="cachewarmer-new-sitemap-url">{{ 'Sitemap URL'|t }}</label>
      <input type="url" id="cachewarmer-new-sitemap-url" name="url" placeholder="https://example.com/sitemap.xml" required class="form-url" />
    </div>
    <div class="cachewarmer-form-row">
      <label for="cachewarmer-new-sitemap-frequency">{{ 'Interval (optional)'|t }}</label>
      <select id="cachewarmer-new-sitemap-frequency" name="cron_frequency" class="form-select">
        <option value="none">{{ 'No schedule'|t }}</option>
        <option value="hourly">{{ 'Hourly'|t }}</option>
        <option value="every_6_hours">{{ 'Every 6 Hours'|t }}</option>
        <option value="every_12_hours">{{ 'Every 12 Hours'|t }}</option>
        <option value="daily">{{ 'Daily'|t }}</option>
      </select>
    </div>
    <div class="cachewarmer-form-row" id="cachewarmer-start-time-wrap" style="display:none;">
      <label for="cachewarmer-new-sitemap-hour">{{ 'Start Time'|t }}</label>
      <select id="cachewarmer-new-sitemap-hour" name="cron_hour" class="form-select">
        {% for h in 0..23 %}
          <option value="{{ h }}"{% if h == 3 %} selected{% endif %}>{{ '%02d:00'|format(h) }}</option>
        {% endfor %}
      </select>
    </div>
    <div class="cachewarmer-form-row">
      <button type="button" id="cachewarmer-add-sitemap" class="button button--primary">{{ 'Add Sitemap'|t }}</button>
      <span id="cachewarmer-sitemap-status" class="cachewarmer-inline-status"></span>
    </div>
  </fieldset>

  {# Bulk Import #}
  <fieldset class="cachewarmer-add-sitemap-form" style="margin-top: 24px;">
    <legend>{{ 'Bulk Import Sitemaps'|t }}</legend>
    <div class="cachewarmer-form-row">
      <label for="cachewarmer-bulk-urls">{{ 'Sitemap URLs (one per line)'|t }}</label>
      <textarea id="cachewarmer-bulk-urls" rows="5" class="form-textarea" placeholder="https://example.com/sitemap.xml&#10;https://another-site.com/sitemap.xml"></textarea>
    </div>
    <div class="cachewarmer-form-row">
      <button type="button" id="cachewarmer-bulk-import" class="button button--primary">{{ 'Import All'|t }}</button>
      <button type="button" id="cachewarmer-detect-sitemaps" class="button">{{ 'Auto-Detect Local Sitemaps'|t }}</button>
      <span id="cachewarmer-bulk-status" class="cachewarmer-inline-status"></span>
    </div>
  </fieldset>

  {# Sitemaps Table #}
  <h3>{{ 'Registered Sitemaps'|t }}</h3>
  <table class="cachewarmer-sitemaps-table">
    <thead>
      <tr>
        <th>{{ 'Domain'|t }}</th>
        <th>{{ 'URL'|t }}</th>
        <th>{{ 'Cron'|t }}</th>
        <th>{{ 'Last Warmed'|t }}</th>
        <th>{{ 'Actions'|t }}</th>
      </tr>
    </thead>
    <tbody id="cachewarmer-sitemaps-tbody">
      {% for sitemap in sitemaps %}
      <tr data-sitemap-id="{{ sitemap.id }}">
        <td>{{ sitemap.domain }}</td>
        <td><a href="{{ sitemap.url }}" target="_blank" rel="noopener">{{ sitemap.url }}</a></td>
        <td>{{ sitemap.cron_expression ?: 'None'|t }}</td>
        <td>{{ sitemap.last_warmed_at ?: 'Never'|t }}</td>
        <td>
          <button class="button button--small button--primary cachewarmer-btn-warm-sitemap" data-sitemap-id="{{ sitemap.id }}">{{ 'Warm Now'|t }}</button>
          <button class="button button--small button--danger cachewarmer-btn-delete-sitemap" data-sitemap-id="{{ sitemap.id }}">{{ 'Delete'|t }}</button>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
